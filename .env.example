# ══════════════════════════════════════════════════════════════════
# Economic Web Platform — Environment Variables Template
# Copy this file to .env and fill in real values before starting.
#
# SECRETS POLICY — обязательно к прочтению:
#   1. НИКОГДА не коммить .env в git — он в .gitignore, это не случайно.
#   2. Замени ВСЕ значения-плейсхолдеры (your-*, REPLACE_ME) на реальные.
#   3. DJANGO_SECRET_KEY должен быть уникален для каждого окружения.
#      Генерация: python -c "import secrets; print(secrets.token_hex(32))"
#   4. При малейшем подозрении на утечку — немедленно ротируй ключ:
#      - Groq: https://console.groq.com → API Keys → Revoke & New
#      - Gemini: https://aistudio.google.com → API Keys
#      - OpenAI: https://platform.openai.com/api-keys
#      - Google OAuth: https://console.cloud.google.com → Credentials → Regenerate
#   5. Не передавай .env через мессенджеры, email или публичные ссылки.
#      Используй менеджер секретов (1Password, Vault, GitHub Secrets).
# ══════════════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────────────
# Set to "production" to enable strict security checks on startup.
# In production mode the app will REFUSE to start if SECRET_KEY is
# left at the insecure default "dev-secret-key".
APP_ENV=development

# ── Django secret key ──────────────────────────────────────────────
# REQUIRED in production. Must be a long random string (50+ chars).
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# Example (do NOT use this value — generate your own):
#   DJANGO_SECRET_KEY=3f8a1c2e4b7d9f0a2c5e8b1d4f7a0c3e6b9d2f5a8c1e4b7d0f3a6c9e2b5d8f1a
DJANGO_SECRET_KEY=REPLACE_ME_generate_with_python_secrets_token_hex_32

# ── Django settings ────────────────────────────────────────────────
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Django database (leave blank to use SQLite) ────────────────────
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=ewp_django
# DJANGO_DB_USER=postgres
# DJANGO_DB_PASSWORD=postgres
# DJANGO_DB_HOST=db
# DJANGO_DB_PORT=5432

# ── FastAPI settings ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./fastapi.db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ewp_fastapi

DJANGO_AUTH_URL=http://127.0.0.1:8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT / AuthZ ────────────────────────────────────────────────────
# FastAPI uses DJANGO_SECRET_KEY (above) to verify JWT signatures.
#
# AUTHZ_INTROSPECT_STRICT (default: 1 — recommended for production)
#   =1  FastAPI returns HTTP 503 if Django introspection is unreachable.
#       This is the safe "fail-closed" mode: no token is accepted without
#       a live agreement check from Django.
#   =0  FastAPI falls back to JWT claims if Django is unreachable.
#       WARNING: in this mode a token with a revoked agreement or changed
#       role will still be accepted during the Django downtime window.
#       Only use =0 for local development where Django may be stopped.
AUTHZ_INTROSPECT_STRICT=1
AUTHZ_CACHE_TTL_SECONDS=60
AUTHZ_INTROSPECT_TIMEOUT_SECONDS=3.5

# ── Rate limiting (Redis-backed token bucket) ──────────────────────
# Redis URL for the rate limiter.
# Leave empty to run in permissive mode (no limiting — dev default).
# Docker: redis://redis:6379/0   Local Redis: redis://127.0.0.1:6379/0
REDIS_URL=

RATE_LIMIT_ENABLED=1
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=20

# Behaviour when Redis is unreachable:
#   1 = fail-open  → allow all requests (safe for dev, data loss for prod)
#   0 = fail-closed → return HTTP 503   (recommended for production)
# Default: 1 in development (APP_ENV != "production"), 0 in production.
RATE_LIMIT_REDIS_FAIL_OPEN=1

# ── AI chart explanation ───────────────────────────────────────────
# Provider: "auto" tries Groq → Gemini → OpenAI in order.
# If no key is set, local statistical fallback is used (always works).
CHART_EXPLAIN_PROVIDER=auto

# Get a free Groq key at https://console.groq.com
GROQ_API_KEY=

# Get a free Gemini key at https://aistudio.google.com
GEMINI_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

CHART_EXPLAIN_MAX_COUNTRIES=4
CHART_EXPLAIN_MAX_INDICATORS=4

# ── Google OAuth2 ──────────────────────────────────────────────────
# Obtain at: https://console.cloud.google.com → APIs & Services → Credentials
# Create an "OAuth 2.0 Client ID" of type "Web application".
# Authorized redirect URIs: not needed for the ID token flow.
# Authorized JavaScript origins: http://localhost:5173 (for local dev)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET is not required for the ID token verification flow.
# Add it if you later implement the authorization code exchange flow.
# GOOGLE_CLIENT_SECRET=

# ── Frontend (Vite) ────────────────────────────────────────────────
VITE_DJANGO_URL=http://127.0.0.1:8000/api
VITE_FASTAPI_URL=http://127.0.0.1:8001/api/v1
# Must match GOOGLE_CLIENT_ID above (exposed to browser):
VITE_GOOGLE_CLIENT_ID=
